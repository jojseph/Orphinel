job_scheduling_data.xml
*.psess
*.vsp
*.vspx
*.sap

# Caliburn.Micro (removes unwanted NuGet Performance logs)
Reference.cache

# CLion
.idea/

# JRebel
rebel.xml
rebel-remote.xml

# SonarLint
.sonarlint/

# Omnisharp
.omnisharp/

# Metadata used by PyCharm
.idea/

# JetBrains Rider
.idea/
*.sln.iml

# Web
node_modules/
dist/
